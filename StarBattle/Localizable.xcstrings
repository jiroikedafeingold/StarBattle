          }
        }
      }
    },
    "Look for a row, column or region whose %@ can only fit one way — small or cramped regions are a great first move." : {
      "comment" : "A tip advising the user to start placing pieces in cramped rows, columns, or regions.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suche eine Zeile, Spalte oder Region, deren %@ nur auf eine Weise passen – kleine oder enge Regionen sind ein guter erster Zug."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Busca una fila, columna o región cuyos %@ solo encajen de una forma: las regiones pequeñas o apretadas son un gran primer movimiento."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cherche une ligne, colonne ou région dont les %@ ne tiennent que d'une seule façon — les petites régions ou les régions serrées sont un excellent premier coup."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cerca una riga, colonna o regione i cui %@ entrano in un solo modo: le regioni piccole o strette sono un'ottima prima mossa."
          }
        },
