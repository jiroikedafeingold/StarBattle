        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocca «Verifica» per segnalare %1$@ sbagliati. Tieni premuto «Verifica» per un controllo più approfondito che segnala anche ogni punto messo su una casella che in realtà richiede una %3$@."
          }
        },
        "ja" : {
