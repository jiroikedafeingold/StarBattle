          }
        }
      }
    },
    "If a line still needs two %@ and has exactly two open squares, both must be %@. If a line already has its two, every other square is empty." : {
      "comment" : "A tip that describes how to use the \"Count the gaps\" tactic. The argument is the name of the piece.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
