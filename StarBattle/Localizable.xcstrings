          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn einer Linie noch ihre %1$@ fehlt und sie nur ein freies Feld hat, ist dieses Feld die Lösung. Sobald eine Linie ihre %2$@ hat, ist jedes andere Feld ein Punkt."
