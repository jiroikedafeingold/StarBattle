    "A bite-size logic puzzle. Fill the board with %@ using pure deduction — no luck required." : {
      "comment" : "The body of the first slide in the onboarding.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
