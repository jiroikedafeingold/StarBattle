    "Tap Check to flag wrong %@. Press and hold Check for a deeper check that also flags any dot you put on a square that actually needs %@ %@." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe auf „Prüfen“, um falsche %1$@ zu markieren. Halte „Prüfen“ gedrückt für eine genauere Prüfung, die auch jeden Punkt markiert, den du auf ein Feld gesetzt hast, das eigentlich eine %3$@ braucht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tap Check to flag wrong %1$@. Press and hold Check for a deeper check that also flags any dot you put on a square that actually needs %2$@ %3$@."
